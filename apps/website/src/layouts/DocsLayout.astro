---
import BaseLayout from './BaseLayout.astro';

const docs = [
  { slug: 'getting-started', title: '快速开始' },
  { slug: 'project-structure', title: '项目结构' },
  { slug: 'packaging', title: '打包与校验' },
  { slug: 'container-limits', title: '容器约束' },
  { slug: 'official-resources', title: '官方资源' },
  { slug: 'monorepo', title: '在 Monorepo 贡献' },
];

const { slug, title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="doc-layout">
    <aside class="doc-nav" aria-label="文档导航">
      {
        docs.map((item) => (
          <a href={`/docs/${item.slug}/`} aria-current={item.slug === slug ? 'page' : undefined}>
            {item.title}
          </a>
        ))
      }
    </aside>
    <article class="doc">
      <slot />
    </article>
  </div>
</BaseLayout>
