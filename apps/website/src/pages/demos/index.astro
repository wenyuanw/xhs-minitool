---
import BaseLayout from '../../layouts/BaseLayout.astro';
import demos from '../../data/demos.json';
---

<BaseLayout title="Demos" description="浏览本仓库内置的小红书小工具示例。">
  <main class="section">
    <h1>Demos</h1>
    <p class="lead">以下为 monorepo 中已构建的小红书小工具，可在浏览器中预览（行为接近容器静态加载）。</p>
    <div class="demo-grid">
      {
        demos.map((demo) => (
          <a class="demo-link" href={`/demos/${demo.id}/`}>
            <h2>{demo.title}</h2>
            <p>{demo.description}</p>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>
